# Application — copy to `.env` (never commit `.env`; rotate keys if leaked)
APP_ENV=local
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=INFO
LOG_FORMAT=text

# API auth (HIGHLY recommended if not localhost-only)
API_AUTH_ENABLED=false
API_AUTH_HEADER=X-API-Key
API_AUTH_TOKEN=

# WebSocket auth (dashboard)
WS_AUTH_ENABLED=false
WS_AUTH_TOKEN=

# Database — use PostgreSQL + pgvector for production (see docker-compose.yml).
# For local quick dev without Docker you may use SQLite, but vector search
# falls back to slower in-Python L2 over JSON-stored embeddings:
# DATABASE_URL=sqlite:///./dev.sqlite
DATABASE_URL=postgresql+psycopg://postgres:postgres@db:5432/crypto_bot
REDIS_URL=redis://redis:6379/0

# Production (docker-compose.prod.yml): set strong POSTGRES_PASSWORD in the environment
# before bringing the stack up. After first deploy run: alembic upgrade head

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_CHAT_ID=
TELEGRAM_GROUP_CHAT_ID=
TELEGRAM_ADMIN_USER_ID=

# Exchange
EXCHANGE_NAME=binance
EXCHANGE_TESTNET=true
# Market type used by BOTH the scanner and the live signal pipeline.
# Must match the products you actually intend to trade: spot | swap | future.
EXCHANGE_MARKET_TYPE=swap
# Approved-but-stale guard: drop broadcast if live ticker drifted by more
# than this percent vs the strategy's entry price.
MAX_BROADCAST_DRIFT_PERCENT=0.75

# Signal mode
APPROVAL_MODE=manual_approval

# Risk management
SIGNAL_COOLDOWN_MINUTES=45
MIN_RISK_REWARD_RATIO=1.2

# AI / Knowledge base
OPENAI_API_KEY=
EMBEDDING_MODEL=text-embedding-3-small
REASONING_MODEL=gpt-4.1-mini
# In-memory LRU cache for embeddings (0 disables caching).
EMBEDDING_CACHE_SIZE=512
# Skip the AI explanation call for HOLD signals (cost saver).
SKIP_REASONING_ON_HOLD=true

# LLM provider for chat completions. Embeddings stay on OpenAI (set OPENAI_API_KEY for them).
# LLM_PROVIDER one of: openai | deepseek | anthropic
LLM_PROVIDER=openai
LLM_API_KEY=
LLM_BASE_URL=
LLM_MODEL=
LLM_REQUEST_TIMEOUT=15.0

# Optional: TradingAgents reviewer/gate
TRADINGAGENTS_ENABLED=false
TRADINGAGENTS_PROVIDER=openai
TRADINGAGENTS_MODEL=gpt-4.1-mini
TRADINGAGENTS_REASONING_EFFORT=medium
TRADINGAGENTS_MODE_A_ENABLED=false
TRADINGAGENTS_MODE_B_ENABLED=false
TRADINGAGENTS_GATE_MIN_SCORE=65.0

# Trading pairs
SYMBOLS=BTC/USDT
TIMEFRAMES=15m

# Strategy
STRATEGY=ema_rsi
EMA_FAST=12
EMA_SLOW=26
RSI_PERIOD=14
RSI_LONG_THRESHOLD=70
RSI_SHORT_THRESHOLD=30
TAKE_PROFIT_R_MULTIPLE=2.0
STOP_LOSS_BUFFER_PERCENT=1.0

# Approval & scheduling
MANUAL_APPROVAL_TIMEOUT_SECONDS=300
SCAN_INTERVAL_SECONDS=300

# Outcome tracker — resolves broadcast signals against subsequent OHLCV.
# A signal that hasn't hit TP/SL within max-age hours is marked 'expired'.
OUTCOME_TRACKER_INTERVAL_SECONDS=600
OUTCOME_TRACKER_MAX_AGE_HOURS=72

# Multi-timeframe trend confirmation. Map base TF -> higher TF.
# Strategies block LONGs against a higher-TF downtrend and SHORTs against an uptrend.
HIGHER_TIMEFRAME_ENABLED=true
HIGHER_TIMEFRAME_MAP=5m=1h,15m=4h,1h=4h,4h=1d
HIGHER_TIMEFRAME_LOOKBACK=300

# Sentiment tie-breaker (free CryptoPanic public posts; needs free auth_token).
# When score opposes the signal direction beyond block_threshold, confidence
# is reduced by confidence_penalty and the reason is annotated.
SENTIMENT_ENABLED=false
CRYPTOPANIC_AUTH_TOKEN=
SENTIMENT_CACHE_TTL_SECONDS=600
SENTIMENT_REQUEST_TIMEOUT=8.0
SENTIMENT_BLOCK_THRESHOLD=0.4
SENTIMENT_CONFIDENCE_PENALTY=15.0
SENTIMENT_MIN_POSTS=3

# Optional: video transcription script bundles ffmpeg via:
#   pip install -e ".[transcription]"
