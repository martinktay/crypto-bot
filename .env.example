# Copy to `.env` (never commit `.env`; rotate keys if leaked).

# Zobo Signal Bot — application
APP_ENV=local
APP_DISPLAY_NAME=Zobo Signal Bot
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=INFO
LOG_FORMAT=text

# API auth (HIGHLY recommended if not localhost-only)
API_AUTH_ENABLED=false
API_AUTH_HEADER=X-API-Key
API_AUTH_TOKEN=

# WebSocket auth (dashboard)
WS_AUTH_ENABLED=false
WS_AUTH_TOKEN=

# Database — use PostgreSQL + pgvector for production (see docker-compose.yml).
# For local quick dev without Docker you may use SQLite, but vector search
# falls back to slower in-Python L2 over JSON-stored embeddings:
# DATABASE_URL=sqlite:///./dev.sqlite
DATABASE_URL=postgresql+psycopg://postgres:postgres@db:5432/crypto_bot
REDIS_URL=redis://redis:6379/0

# Production (docker-compose.prod.yml): set strong POSTGRES_PASSWORD in the environment
# before bringing the stack up. After first deploy run: alembic upgrade head

# Telegram (values in this file apply to the app; pasting secrets only in Cursor chat does not.)
TELEGRAM_BOT_TOKEN=
# Your private DM with the bot (for /commands and copy of notifications).
TELEGRAM_ADMIN_CHAT_ID=
# Alternative name for DM chat to the admin (same value as TELEGRAM_ADMIN_CHAT_ID):
# TELEGRAM_CHAT_ID=
# Group/supergroup id so signal cards are posted in the group (supergroups look like -100…).
# Setup: add the bot to the group, allow it to post (group admin + “Send messages” is easiest).
# Easiest way to copy the id: from your admin account run /chatinfo inside the group (bot must be
# running with TELEGRAM_ADMIN_USER_ID set to your numeric user id). Paste chat.id here.
# Alternative: post any message in the group, then open (in a private browser tab)
#   https://api.telegram.org/bot<YOUR_BOT_TOKEN>/getUpdates
# and read "chat":{"id":…} on the group update (never share the token or full URL).
TELEGRAM_GROUP_CHAT_ID=
# If the supergroup uses Topics ("forum"): bot messages must specify a topic thread id.
# General chat is often 1; or copy the thread id from a topic link. Leave empty for normal groups.
TELEGRAM_GROUP_MESSAGE_THREAD_ID=
#
# --- Group signals not appearing? (checklist) ---
# 1) Wrong id source: /chatinfo must be run IN THE GROUP, not in private chat with the bot.
#    You need chat.type "group" or "supergroup" and an id usually like -1001234567890.
#    Your private DM id (positive, e.g. 628...) is only for TELEGRAM_ADMIN_CHAT_ID.
# 2) Topics/forum enabled: add TELEGRAM_GROUP_MESSAGE_THREAD_ID (try 1 for General) — without it Telegram
#    may reject sendMessage while your DM delivery still appears to work elsewhere.
# 3) .env typo: TELEGRAM_GROUP_CHAT_ID has no stray quotes (or use unquoted numeric); keep the minus sign for -100….
#    Settings strip common wrapping quotes, but restarting the API is still required after changes.
# 4) Restart after editing .env — the process reads settings at startup (uvicorn / Docker API container).
# 5) TELEGRAM_BOT_TOKEN must belong to the same @Bot that is admin in the group.
# 6) If /chatinfo fails in the group with "Unauthorized", TELEGRAM_ADMIN_USER_ID must equal the
#    numeric id of whoever sends /chatinfo (not the bot's id, not the group's id).
# 7) If the group is heavily restricted, try sending /chatinfo@YourBotUsername (mention form).
# 8) Server logs: failures show as "Telegram send failed"; success path logs "broadcast delivered".
#    Also check logs for incomplete broadcasts (mentions forum thread id hint).
#
TELEGRAM_ADMIN_USER_ID=
# Alternative: TELEGRAM_USER_ID=
# If both TELEGRAM_GROUP_CHAT_ID and TELEGRAM_ADMIN_CHAT_ID are set, each signal is sent
# to the group first, then to your admin DM (deduped if you ever set the same id twice).

# Exchange
# EXCHANGE_NAME is the *default* exchange used when a SYMBOLS entry has no
# explicit prefix. EXCHANGES is the full registry the bot is allowed to
# fetch from. Symbols can be qualified, e.g.
#   SYMBOLS=binance:BTC/USDT, bybit:SOL/USDT, mexc:DOGE/USDT, ETH/USDT
# (the unqualified ETH/USDT is fetched from EXCHANGE_NAME).
EXCHANGE_NAME=binance
EXCHANGES=binance
EXCHANGE_TESTNET=true
# Market type used by BOTH the scanner and the live signal pipeline.
# Must match the products you actually intend to trade: spot | swap | future.
EXCHANGE_MARKET_TYPE=swap
# Approved-but-stale guard: drop broadcast if live ticker drifted by more
# than this percent vs the strategy's entry price.
MAX_BROADCAST_DRIFT_PERCENT=0.75

# Outbound proxy (optional). Set when the host network blocks exchange
# APIs — common with UK/EU consumer ISPs and corporate DNS filters that
# block api.bybit.com / api.mexc.com / api.binance.com. Both ccxt and
# urllib's reachability probes pick these up.
#   HTTPS_PROXY=http://user:pass@proxy.example.com:8080
#   HTTP_PROXY=http://user:pass@proxy.example.com:8080
HTTP_PROXY=
HTTPS_PROXY=

# Risk management
SIGNAL_COOLDOWN_MINUTES=45
MIN_RISK_REWARD_RATIO=1.2

# AI / Knowledge base
OPENAI_API_KEY=
EMBEDDING_MODEL=text-embedding-3-small
REASONING_MODEL=gpt-4.1-mini
# In-memory LRU cache for embeddings (0 disables caching).
EMBEDDING_CACHE_SIZE=512
# Skip the AI explanation call for HOLD signals (cost saver).
SKIP_REASONING_ON_HOLD=true

# LLM provider for chat completions. Embeddings stay on OpenAI (set OPENAI_API_KEY for them).
# LLM_PROVIDER one of: openai | deepseek | anthropic
LLM_PROVIDER=openai
LLM_API_KEY=
LLM_BASE_URL=
LLM_MODEL=
LLM_REQUEST_TIMEOUT=15.0

# Optional: TradingAgents reviewer/gate
TRADINGAGENTS_ENABLED=false
TRADINGAGENTS_PROVIDER=openai
TRADINGAGENTS_MODEL=gpt-4.1-mini
TRADINGAGENTS_REASONING_EFFORT=medium
TRADINGAGENTS_MODE_A_ENABLED=false
TRADINGAGENTS_MODE_B_ENABLED=false
TRADINGAGENTS_GATE_MIN_SCORE=65.0

# Trading pairs
SYMBOLS=BTC/USDT
# Comma-separated CCXT timeframes. Bare numbers become bars (15 -> 15m, 60 -> 1h).
TIMEFRAMES=15m,1h,4h
# Sync bot_settings.timeframes + strategy from .env on each startup (SYMBOLS unchanged).
# SYNC_RUNTIME_TIMEFRAMES_FROM_ENV=true

# Strategy
STRATEGY=ema_rsi
EMA_FAST=12
EMA_SLOW=26
RSI_PERIOD=14
RSI_LONG_THRESHOLD=70
RSI_SHORT_THRESHOLD=30
TAKE_PROFIT_R_MULTIPLE=2.0
STOP_LOSS_BUFFER_PERCENT=1.0
# Classic candlestick pattern gates (engulfing, hammer, stars, etc.).
CANDLESTICK_PATTERNS_ENABLED=true
# If true, require at least one confirming pattern in trade direction (stricter, fewer trades).
CANDLESTICK_PATTERNS_STRICT=false

# Scheduling
SCAN_INTERVAL_SECONDS=300

# Outcome tracker — resolves broadcast signals against subsequent OHLCV.
# A signal that hasn't hit TP/SL within max-age hours is marked 'expired'.
OUTCOME_TRACKER_INTERVAL_SECONDS=600
OUTCOME_TRACKER_MAX_AGE_HOURS=72

# Multi-timeframe trend confirmation. Map base TF -> higher TF.
# Strategies block LONGs against a higher-TF downtrend and SHORTs against an uptrend.
HIGHER_TIMEFRAME_ENABLED=true
HIGHER_TIMEFRAME_MAP=5m=1h,15m=4h,1h=4h,4h=1d
HIGHER_TIMEFRAME_LOOKBACK=300
# Multi-TF EMA200 alignment when scanning a base TF (e.g. 15m): fetch each TF strictly higher than the base.
# Tokens all / alltime → monthly (1M) with HTF_ALLTIME_LOOKBACK. Falls back to HIGHER_TIMEFRAME_MAP if disabled or empty fetches.
HTF_ALIGNMENT_ENABLED=true
HTF_ALIGNMENT_TIMEFRAMES=1h,4h,1d,1w,1M,all
HTF_ALLTIME_LOOKBACK=500

# Sentiment tie-breaker (free CryptoPanic public posts; needs free auth_token).
# When score opposes the signal direction beyond block_threshold, confidence
# is reduced by confidence_penalty and the reason is annotated.
SENTIMENT_ENABLED=false
CRYPTOPANIC_AUTH_TOKEN=
SENTIMENT_CACHE_TTL_SECONDS=600
SENTIMENT_REQUEST_TIMEOUT=8.0
SENTIMENT_BLOCK_THRESHOLD=0.4
SENTIMENT_CONFIDENCE_PENALTY=15.0
SENTIMENT_MIN_POSTS=3

# Optional: video transcription script bundles ffmpeg via:
#   pip install -e ".[transcription]"
